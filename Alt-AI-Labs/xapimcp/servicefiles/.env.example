# X OAuth2 client credentials (used for offline refresh).
# Prefer X_CLIENT_ID/X_CLIENT_SECRET; legacy aliases are supported.
X_CLIENT_ID=
X_CLIENT_SECRET=
# X_CONSUMER_KEY=
# X_CONSUMER_SECRET=

# Headless forever: seed once on laptop via `cargo run --bin authorize-x`,
# then set the refresh token here (or via X_REFRESH_TOKEN_FILE).
X_REFRESH_TOKEN=
# X_REFRESH_TOKEN_FILE=/etc/xapimcp/x_refresh_token

# Optional numeric X user id. If omitted, xapimcp resolves via GET /2/users/me using a valid access token.
# X_USER_ID=