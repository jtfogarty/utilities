# Install: sudo mkdir -p /etc/xbookmark-puller && sudo cp to /etc/xbookmark-puller/xbookmark-puller.env && sudo chmod 600 ...

# --- xbookmark-puller (MCP client; no direct X HTTP) ---
SURREAL_MCP_URL=http://127.0.0.1:8800/mcp
SURREAL_MCP_AUTH_TOKEN=

# SurrealDB namespace/database used via SurrealMCP tools (`use_namespace` + `use_database`)
# Set either:
#   NAMESPACE + DATABASE
# or prefixed aliases:
#   SURREALDB_NAMESPACE + SURREALDB_DATABASE
NAMESPACE=
DATABASE=

# Streamable HTTP URL for xapimcp (must expose get_my_bookmarks / delete_bookmark).
X_MCP_URL=http://127.0.0.1:8090/mcp

PULL_INTERVAL_MINUTES=15

# When false, governor pacing waits are skipped (429 JSON fallback still applies).
RATE_LIMIT_ENFORCED=true

# Logs go to stderr (not stdout). If RUST_LOG is unset, xbookmark-puller defaults to info.
# Optional: RUST_LOG=info,xbookmark_puller=debug
# Dry-run: pass --dry-run on the command line (still runs Surreal + governor; skips delete MCP).

# --- xapimcp service itself (not read by xbookmark-puller; keep on xapimcp host/env file) ---
# X_BEARER_TOKEN=
# X_USER_ID=
