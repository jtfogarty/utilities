# Install: sudo mkdir -p /etc/xbookmark-puller && sudo cp to /etc/xbookmark-puller/xbookmark-puller.env && sudo chmod 600 ...

# --- xbookmark-puller (MCP client; no direct X HTTP) ---
SURREAL_MCP_URL=http://127.0.0.1:8080/mcp
SURREAL_MCP_AUTH_TOKEN=

# Streamable HTTP URL for xapimcp (must expose get_my_bookmarks / delete_bookmark).
X_MCP_URL=http://127.0.0.1:8090/mcp
X_MCP_AUTH_TOKEN=

PULL_INTERVAL_MINUTES=15

# Optional: RUST_LOG=info,xbookmark_puller=debug

# --- xapimcp service itself (not read by xbookmark-puller; keep on xapimcp host/env file) ---
# X_BEARER_TOKEN=
# X_USER_ID=
