# github-mcp.env
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_actual_fine_grained_token_here

# Optional but recommended (tune to your needs)
GITHUB_TOOLSETS=repos,issues,pull_requests,actions,code_security
# GITHUB_TOOLS=get_file_contents,create_pull_request,issue_create   # alternative or additive
GITHUB_READ_ONLY=false
GITHUB_LOCKDOWN_MODE=false
GITHUB_HOST=https://api.github.com          # change only if using GitHub Enterprise

# Logging / debug
LOG_LEVEL=info