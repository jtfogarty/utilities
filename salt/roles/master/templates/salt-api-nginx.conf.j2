# Managed by Ansible - do not edit manually
# Nginx reverse proxy for salt-api (HTTPS + HTTP/2)
# CherryPy listens on loopback only; nginx terminates TLS.

server {
    listen {{ salt_api_nginx_listen_port | default(8443) }} ssl;
    server_name {{ ansible_fqdn | default('localhost') }};

    ssl_certificate       {{ salt_ssl_crt }};
    ssl_certificate_key   {{ salt_ssl_key }};

    ssl_protocols         TLSv1.2 TLSv1.3;
    ssl_ciphers           HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    location / {
        proxy_pass http://{{ salt_api_host }}:{{ salt_api_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
        proxy_buffering off;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
