# Managed by Ansible - do not edit manually
# External Authentication for salt-api

external_auth:
  {{ salt_eauth_backend }}:
{% for user in salt_eauth_users %}
    {{ user.username }}:
{% for perm in user.permissions %}
      - {{ perm }}
{% endfor %}
{% endfor %}

# Use the dedicated PAM service file /etc/pam.d/salt-api
# This file contains the minimal working config for Ubuntu PAM:
#   auth     required     pam_unix.so
#   account  required     pam_unix.so
auth_pam_service: salt-api
