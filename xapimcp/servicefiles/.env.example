sudo mkdir -p /etc/xapimcp
sudo tee /etc/xapimcp/xapimcp.env > /dev/null <<EOF
# X.com (Twitter) API credentials
X_BEARER_TOKEN=<your_real_bearer_token_here>
X_USER_ID=<your_user_id_here>

# Optional: logging level
RUST_LOG=info
EOF

# Secure the file (only root can read it)
sudo chmod 600 /etc/xapimcp/xapimcp.env